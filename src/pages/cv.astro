---
import BaseLayout from "../components/layout/BaseLayout.astro";
import AcademicLinks from "../components/academic/AcademicLinks.astro";
import DenoiseHeading from "../components/motion/DenoiseHeading";
import { existsSync } from "node:fs";
import { join } from "node:path";

const sections = [
  { id: "download", label: "Download" },
  { id: "positions", label: "Positions" },
  { id: "education", label: "Education" },
  { id: "adjacent-interests", label: "Adjacent Interests" },
  { id: "links", label: "Links" },
];

const cvPath = "/files/cv_jan_tauberschmidt.pdf";
const hasCv = existsSync(join(process.cwd(), "public", "files", "cv_jan_tauberschmidt.pdf"));
---

<BaseLayout title="CV" sections={sections}>
  <section class="page-section cv-section-download" id="download">
    <DenoiseHeading text="CV" as="h1" client:visible />
    <p class="lead">
      {
        hasCv ? (
          <>
            Please find a full CV as a PDF download below. For publication details and research code, please also see the{" "}
            <a class="cv-inline-link" href="/publications/">Publications page</a> and linked profiles.
          </>
        ) : (
          <>
            A current CV can be added as a PDF at <code>public/files/cv_jan_tauberschmidt.pdf</code>. For publication details and research code, please also see the{" "}
            <a class="cv-inline-link" href="/publications/">Publications page</a> and linked profiles.
          </>
        )
      }
    </p>
    <div class="button-row">
      {hasCv && <a class="button primary" href={cvPath}>Download CV</a>}
      {!hasCv && <span class="button primary disabled" aria-disabled="true">Download CV</span>}
      <a class="button" href="/publications/">Publications</a>
      <a class="button" href="https://github.com/jantauberschmidt">GitHub</a>
    </div>
    <p class="muted cv-note">Last updated: May 2026</p>
  </section>

  <section class="page-section cv-section-following" id="positions">
    <DenoiseHeading text="Positions" client:visible />
    <div class="cv-timeline">
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">Since 11/2024</p>
        <div class="cv-timeline__body">
          <h3>Researcher</h3>
          <p>German Research Center for Artificial Intelligence (DFKI)</p>
          <p class="muted">Department of Data Science and its Applications.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">04/2024–10/2024</p>
        <div class="cv-timeline__body">
          <h3>Master Thesis Student</h3>
          <p>Porsche Motorsport</p>
          <p class="muted">Master’s thesis: A Domain-informed Reinforcement Learning Race Driver Model.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">09/2023–03/2024</p>
        <div class="cv-timeline__body">
          <h3>Research Assistant</h3>
          <p>German Research Center for Artificial Intelligence (DFKI)</p>
          <p class="muted">Work on spatio-temporal anomaly detection.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">09/2022–10/2023</p>
        <div class="cv-timeline__body">
          <h3>Research Assistant</h3>
          <p>Fraunhofer ITWM</p>
          <p class="muted">Department for System Analysis, Prediction and Control.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">03/2022–09/2022</p>
        <div class="cv-timeline__body">
          <h3>Internship</h3>
          <p>Porsche Motorsport</p>
          <p class="muted">Toolchain development for vehicle science in LMDh and Formula E.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="page-section" id="education">
    <DenoiseHeading text="Education" client:visible />
    <div class="cv-timeline">
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">Since 2025</p>
        <div class="cv-timeline__body">
          <h3>Ph.D. Student</h3>
          <p>RPTU Kaiserslautern</p>
          <p class="muted">Supervised by Prof. Sebastian J. Vollmer.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">10/2022–12/2024</p>
        <div class="cv-timeline__body">
          <h3>M.Sc. Mathematics</h3>
          <p>RPTU Kaiserslautern</p>
          <p class="muted">Specialization: Systems and Control.</p>
          <p class="muted">Master’s thesis: A Domain-informed Reinforcement Learning Race Driver Model.</p>
        </div>
      </article>
      <article class="cv-timeline__entry">
        <p class="cv-timeline__date">10/2018–03/2023</p>
        <div class="cv-timeline__body">
          <h3>B.Sc. Mathematics</h3>
          <p>TU Kaiserslautern</p>
          <p class="muted">Specialization: Industrial Mathematics.</p>
          <p class="muted">Bachelor’s thesis: Model-based torque control of an electric all-wheel driven race car.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="page-section" id="adjacent-interests">
    <DenoiseHeading text="Adjacent Interests" client:visible />
    <a class="cv-activity-card" href="https://www.karat-racing.de" target="_blank" rel="noopener noreferrer">
      <div class="cv-activity-card__header">
        <p class="section-eyebrow">Formula Student / KaRaT e.V.</p>
        <span class="cv-activity-card__link">karat-racing.de</span>
      </div>
      <div class="cv-activity-card__list">
        <article class="cv-activity-card__entry">
          <p class="cv-activity-card__date">09/2020-09/2021</p>
          <div>
            <h3>First Chairman of KaRaT e.V.</h3>
            <p class="muted">Team leadership in a Formula Student project, including organizational responsibility, financial planning, and technical coordination in the mechanics division.</p>
          </div>
        </article>
        <article class="cv-activity-card__entry">
          <p class="cv-activity-card__date">Since 11/2019</p>
          <div>
            <h3>Formula Student Electric Team Member</h3>
            <p>Kaiserslautern Racing Team — KaRaT e.V., TU Kaiserslautern.</p>
          </div>
        </article>
      </div>
    </a>
  </section>

  <section class="page-section" id="links">
    <DenoiseHeading text="Links" client:visible />
    <div class="cv-links-panel">
      <AcademicLinks />
    </div>
  </section>
</BaseLayout>

<style>
  .cv-section-download {
    padding-bottom: 0.7rem;
  }

  .cv-section-following {
    padding-top: 0.7rem;
  }

  .cv-note {
    margin-top: 1rem;
    font-size: 0.88rem;
  }

  .cv-inline-link {
    color: var(--accent);
    font-weight: 620;
    text-decoration: none;
    text-underline-offset: 0.18em;
    transition: color 160ms ease;
  }

  .cv-inline-link:hover,
  .cv-inline-link:focus-visible {
    color: var(--accent-2);
    text-decoration: underline;
  }

  .cv-timeline {
    position: relative;
    display: grid;
    gap: 1.1rem;
    margin-top: 1.3rem;
    padding-left: 1.2rem;
  }

  .cv-timeline::before {
    content: "";
    position: absolute;
    top: 0.25rem;
    bottom: 0.25rem;
    left: 0.3rem;
    width: 1px;
    background: color-mix(in srgb, var(--accent) 22%, var(--border));
  }

  .cv-timeline__entry {
    position: relative;
    display: grid;
    grid-template-columns: minmax(8.5rem, 11rem) minmax(0, 1fr);
    gap: 1.1rem;
    padding-left: 1.15rem;
  }

  .cv-timeline__entry::before {
    content: "";
    position: absolute;
    left: -0.1rem;
    top: 0.16rem;
    width: 0.78rem;
    height: 0.78rem;
    border-radius: 999px;
    background: var(--surface);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .cv-timeline__date {
    margin: 0;
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .cv-timeline__body {
    min-width: 0;
  }

  .cv-timeline__body h3 {
    margin-bottom: 0.18rem;
    font-size: 1rem;
  }

  .cv-timeline__body p {
    margin: 0 0 0.2rem;
  }

  .cv-activity-card {
    display: grid;
    gap: 1rem;
    margin-top: 1.2rem;
    padding: 1.2rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--border));
    border-radius: 8px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 6%, white), rgba(255, 255, 255, 0.96));
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .cv-activity-card:hover,
  .cv-activity-card:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 32%, var(--border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 9%, white), rgba(255, 255, 255, 0.98));
    transform: translateY(-1px);
  }

  .cv-activity-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 40%, transparent);
    outline-offset: 3px;
  }

  .cv-activity-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .cv-activity-card__header .section-eyebrow {
    margin: 0;
  }

  .cv-activity-card__link {
    color: var(--muted);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .cv-activity-card__list {
    display: grid;
    gap: 0.95rem;
  }

  .cv-activity-card__entry {
    display: grid;
    grid-template-columns: minmax(8.5rem, 10rem) minmax(0, 1fr);
    gap: 1rem;
    padding-top: 0.95rem;
    border-top: 1px solid color-mix(in srgb, var(--accent) 10%, var(--border));
  }

  .cv-activity-card__entry:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .cv-activity-card__date {
    margin: 0;
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .cv-activity-card__entry h3 {
    margin-bottom: 0.18rem;
    font-size: 1rem;
  }

  .cv-activity-card__entry p {
    margin: 0;
  }

  .cv-links-panel {
    margin-top: 1.2rem;
    padding: 1.15rem 1.2rem;
    border: 1px solid color-mix(in srgb, var(--accent) 12%, var(--border));
    border-radius: 8px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 4%, white), rgba(255, 255, 255, 0.98));
  }

  .cv-links-panel :global(.academic-links) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem 1rem;
    align-items: stretch;
  }

  .cv-links-panel :global(.academic-link) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.8rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--accent) 10%, var(--border));
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    font-size: 0.94rem;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      background 160ms ease;
  }

  .cv-links-panel :global(.academic-link:hover),
  .cv-links-panel :global(.academic-link:focus-visible) {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
    background: rgba(255, 255, 255, 0.96);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .cv-links-panel :global(.academic-link__icon) {
    color: var(--muted);
  }

  .button.disabled {
    cursor: not-allowed;
    opacity: 0.58;
  }

  @media (max-width: 720px) {
    .cv-section-download {
      padding-bottom: 0.6rem;
    }

    .cv-section-following {
      padding-top: 0.6rem;
    }

    .cv-timeline__entry,
    .cv-activity-card__entry {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .cv-timeline {
      padding-left: 0.95rem;
    }

    .cv-activity-card__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    .cv-links-panel :global(.academic-links) {
      grid-template-columns: 1fr;
    }
  }
</style>
