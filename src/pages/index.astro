---
import BaseLayout from "../components/layout/BaseLayout.astro";
import AcademicLinks from "../components/academic/AcademicLinks.astro";
import DeferredGlobe from "../components/motion/DeferredGlobe";

const sections = [
  { id: "hello", label: "Hello" },
  { id: "research", label: "Research" },
  { id: "paper", label: "Featured Work" },
  { id: "places", label: "Where We Met" },
];

const locations = [
  { label: "Rio de Janeiro", note: "ICLR 2026", period: "2026", coordinates: [-22.9068, -43.1729] },
  { label: "London", note: "Visited Imperial College and Alan Turing Institute", period: "2025", coordinates: [51.5072, -0.1276] },
  { label: "Porsche Motorsport, Weissach", note: "Internship and Master’s thesis", period: "2022, 2024", coordinates: [48.8294, 8.9192] },
  { label: "Kaiserslautern", note: "DFKI (Researcher)\nFraunhofer ITWM (Research Assistant)\nRPTU (Bachelor's and Master's of Mathematics)", period: "2018-now", coordinates: [49.432, 7.752] },
];
---

<BaseLayout title="Jan Tauberschmidt" sections={sections}>
  <section class="page-section hero" id="hello">
    <div class="hero-copy">
      <p class="hero-kicker">PhD Researcher in Scientific Machine Learning</p>
      <h1 class="text-diffuse letter-noise" data-letter-noise="Hi, I’m Jan Tauberschmidt.">
        <span class="diffuse-base">Hi, I’m Jan Tauberschmidt.</span>
        <span class="diffuse-noise" aria-hidden="true"></span>
      </h1>
    <p class="lead">
     I am excited about machine learning methods that become useful in scientific and physical systems. This is the direction I explore as a Ph.D. student at <a class="hero-inline-link" href="https://rptu.de" target="_blank" rel="noreferrer">RPTU Kaiserslautern</a> and researcher at the <a class="hero-inline-link" href="https://www.dfki.de/web" target="_blank" rel="noreferrer">German Research Center for Artificial Intelligence (DFKI)</a>, working in the <a class="hero-inline-link" href="https://dsa.dfki.de" target="_blank" rel="noreferrer">Department of Data Science and its Applications</a> under the supervision of <a class="hero-inline-link" href="https://dsa.dfki.de/team/members/admin/" target="_blank" rel="noreferrer">Prof. Sebastian J. Vollmer</a>.
    </p>
    </div>
    <div class="hero-companion">
      <div class="hero-side">
        <figure class="denoise-image hero-portrait" data-hero-denoise>
          <img src="/images/MainFoto.JPG" alt="Foto of Jan Tauberschmidt" loading="eager" />
          <canvas aria-hidden="true" class="noise-layer"></canvas>
        </figure>
      </div>
      <div class="hero-socials">
        <AcademicLinks />
      </div>
    </div>
    <div class="hero-meta">
      <div class="interest-weave" aria-label="Research interests">
        <span>Generative models</span>
        <span>Physics-informed ML</span>
        <span>AI4Science</span>
        <span>Control</span>
      </div>
    </div>
  </section>

  <section class="page-section research-snapshot" id="research">
  <p class="section-eyebrow">Research direction</p>
  <p class="lead">
    My research asks how expressive machine learning models can be made useful for scientific problems without ignoring the structure we already know. I work on generative modeling, physics- and domain-informed learning, and control, aiming to bridge the gap between black-box prediction and classical mathematical modeling.
  </p>
</section>

  <section class="page-section paper-section" id="paper">
    <p class="section-eyebrow">A recent piece of this puzzle</p>
    <article class="paper-feature">
      <h2>Physics-Constrained Fine-Tuning of Flow-Matching Models for Generation and Inverse Problems</h2>
      <p>ICLR 2026</p>
      <div class="button-row">
        <a class="button primary" href="https://openreview.net/forum?id=khBHJz2wcV" target="_blank" rel="noreferrer">OpenReview</a>
        <a class="button" href="https://arxiv.org/abs/2508.09156" target="_blank" rel="noreferrer">arXiv</a>
        <a class="button" href="https://github.com/jantauberschmidt/PCFT" target="_blank" rel="noreferrer">Code</a>
        <a class="button" href="/publications/">BibTeX</a>
      </div>
    </article>
  </section>

  <section class="page-section places-section" id="places">
    <div class="places-copy">
      <h2>We may have crossed paths in…</h2>
    </div>
    <div class="places-grid">
      <DeferredGlobe locations={locations} client:only="react" />
      <div class="places-list" aria-label="Places and times">
        {locations.map((location) => (
          <article class="place-row">
            <p class="place-period">{location.period}</p>
            <p class="place-label">{location.label}</p>
            {location.note && <p class="place-note">{location.note}</p>}
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-section {
    padding: clamp(1.8rem, 5vw, 3.4rem) 0;
  }

  .page-section:first-child {
    padding-top: clamp(2rem, 5vw, 3.5rem);
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(19rem, 21rem);
    grid-template-areas:
      "copy companion"
      "meta meta";
    gap: clamp(0.9rem, 2.2vw, 1.4rem);
    align-items: stretch;
    width: 100%;
    overflow: visible;
  }

  .hero-copy {
    grid-area: copy;
    display: grid;
    gap: 0.9rem;
    max-width: none;
    z-index: 2;
    padding-top: 0.35rem;
    align-self: stretch;
    min-width: 0;
  }

  .hero-copy .lead,
  .research-snapshot .lead {
    text-align: justify;
    text-justify: inter-word;
  }

  .hero-inline-link {
    color: inherit;
    font-weight: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 16%, transparent);
    transition:
      color 160ms ease,
      border-color 160ms ease;
  }

  .hero-inline-link:hover,
  .hero-inline-link:focus-visible {
    color: var(--accent);
    border-bottom-color: color-mix(in srgb, var(--accent) 65%, transparent);
    text-decoration: none;
  }

  .hero-kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.98rem;
    font-weight: 620;
  }

  .hero-companion {
    grid-area: companion;
    display: grid;
    grid-template-columns: 10.2rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: stretch;
    align-self: stretch;
    width: 100%;
    height: 100%;
    min-height: 0;
    padding: 0.7rem;
    border: 1px solid rgb(49 95 157 / 0.1);
    border-radius: 14px;
    background: rgb(246 246 242 / 0.9);
    box-shadow: 0 12px 36px rgb(23 23 23 / 0.04);
    z-index: 2;
  }

  .hero-side {
    display: grid;
    align-content: stretch;
    min-width: 0;
  }

  .hero-socials {
    display: grid;
    align-content: stretch;
    align-self: stretch;
    min-width: 0;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .hero-meta {
    grid-area: meta;
    display: grid;
    align-content: start;
    width: 100%;
    margin-top: 0.1rem;
    padding-top: 0;
    border-top: 0;
    z-index: 2;
  }

  .letter-noise {
    max-width: 11ch;
    font-size: clamp(2.5rem, 4vw, 3.25rem);
    line-height: 0.98;
  }

  .hero :global(.hero-portrait) {
    position: relative;
    z-index: 1;
    align-self: stretch;
    width: 10.2rem;
    height: 100%;
    transform: none;
    box-shadow: none;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero :global(.hero-portrait img) {
    min-height: 0;
    height: 100%;
    filter: brightness(1.2) contrast(1.2);
  }

  .text-diffuse {
    position: relative;
  }

  .diffuse-base {
    display: block;
    color: inherit;
  }

  .diffuse-noise {
    position: absolute;
    inset: 0;
    color: inherit;
    white-space: pre-wrap;
    font-kerning: none;
    font-variant-ligatures: none;
    pointer-events: none;
  }

  .text-diffuse.is-settled .diffuse-noise {
    opacity: 0;
  }

  .text-diffuse:not(.is-settled) .diffuse-base {
    opacity: 0;
  }

  .hero-socials :global(.academic-links) {
    display: grid;
    grid-template-rows: repeat(6, minmax(0, 1fr));
    align-items: stretch;
    justify-items: stretch;
    gap: 0;
    width: 100%;
    margin-top: 0;
    height: 100%;
    min-height: 100%;
    padding: 0;
  }

  .hero-socials :global(.academic-link) {
    justify-content: start;
    align-items: center;
    display: flex;
    width: 100%;
    min-height: 100%;
    padding: 0 0.25rem;
    border: 0;
    background: transparent;
    color: var(--muted);
    font-size: 0.9rem;
    border-radius: 8px;
  }

  .hero-socials :global(.academic-link__label) {
    font-weight: 620;
  }

  .hero-socials :global(.academic-link:hover),
  .hero-socials :global(.academic-link:focus-visible) {
    color: var(--accent);
    transform: none;
  }

  .interest-weave {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    width: 100%;
    gap: 0.34rem;
    max-width: none;
    min-height: 0;
    justify-content: flex-start;
  }

  .interest-weave span {
    padding: 0.22rem 0.44rem;
    border: 1px solid rgb(49 95 157 / 0.16);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.62);
    color: #46504f;
    font-size: 0.69rem;
    font-weight: 680;
    line-height: 1.25;
  }

  .research-snapshot {
    padding-top: 1.6rem;
  }

  .paper-feature {
    display: grid;
    gap: 0.55rem;
    max-width: 50rem;
    padding: clamp(1rem, 2.5vw, 1.35rem);
    border: 1px solid rgb(49 95 157 / 0.2);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.86), rgb(232 240 245 / 0.64)),
      radial-gradient(circle at 88% 18%, rgb(61 140 166 / 0.16), transparent 42%);
    box-shadow: var(--shadow);
  }

  .paper-feature h2 {
    max-width: none;
    font-size: clamp(1.35rem, 2.8vw, 1.72rem);
  }

  .paper-feature p {
    margin-bottom: 0;
    color: var(--accent-2);
    font-weight: 760;
    letter-spacing: 0.06em;
  }

  .places-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.8rem, 2vw, 1.3rem);
    align-items: start;
  }

  .places-copy h2 {
    max-width: none;
    margin-top: 0;
    white-space: nowrap;
  }

  .places-grid {
    display: grid;
    grid-template-columns: minmax(16rem, 24rem) minmax(0, 1fr);
    gap: clamp(1rem, 2.4vw, 1.8rem);
    align-items: center;
  }

  .places-section :global(.interactive-globe) {
    position: relative;
    display: grid;
    grid-template-columns: minmax(14rem, 24rem);
    gap: clamp(1rem, 4vw, 1.6rem);
    align-items: center;
    justify-self: center;
  }

  .places-list {
    max-height: 24rem;
    overflow-y: auto;
    align-self: center;
    margin-block: auto;
    border: 1px solid rgb(49 95 157 / 0.14);
    border-radius: var(--radius);
    background: rgb(255 255 255 / 0.7);
  }

  .place-row {
    display: grid;
    grid-template-columns: 5.3rem minmax(0, 1fr);
    gap: 0.2rem 0.8rem;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid rgb(49 95 157 / 0.12);
  }

  .place-row:last-child {
    border-bottom: 0;
  }

  .place-period,
  .place-label,
  .place-note {
    margin: 0;
  }

  .place-period {
    grid-column: 1;
    grid-row: 1 / span 2;
    color: var(--accent-2);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .place-label {
    grid-column: 2;
    color: var(--text);
    font-size: 0.93rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .place-note {
    grid-column: 2;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.35;
    white-space: pre-line;
  }

  .places-section :global(.interactive-globe-placeholder) {
    width: min(24rem, 100%);
    aspect-ratio: 1;
  }

  .places-section :global(.interactive-globe canvas) {
    width: min(24rem, 100%);
    aspect-ratio: 1;
    cursor: grab;
    touch-action: none;
    border-radius: 50%;
  }

  .places-section :global(.interactive-globe canvas:active) {
    cursor: grabbing;
  }

  .places-section :global(.globe-tooltip) {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 3;
    display: grid;
    width: max-content;
    max-width: 13rem;
    padding: 0.34rem 0.48rem;
    border: 1px solid rgb(226 229 226 / 0.9);
    border-radius: var(--radius);
    background: rgb(255 255 255 / 0.94);
    box-shadow: 0 10px 30px rgb(23 23 23 / 0.08);
    color: var(--text);
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.2;
    opacity: 0;
    pointer-events: none;
    transform: translate(-999px, -999px);
    transition: opacity 120ms ease;
  }

  .places-section :global(.globe-tooltip span) {
    color: var(--muted);
    font-weight: 560;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-areas:
        "copy"
        "companion"
        "meta";
      align-items: start;
    }

    .hero-companion {
      grid-template-columns: 1fr;
      justify-self: stretch;
      height: auto;
    }

    .hero :global(.hero-portrait) {
      max-width: 18rem;
      width: min(100%, 18rem);
      height: auto;
      transform: none;
    }

    .hero-socials {
      padding-bottom: 0;
    }

    .places-grid,
    .places-section :global(.interactive-globe) {
      grid-template-columns: 1fr;
    }

    .places-copy h2 {
      white-space: normal;
    }

    .places-section :global(.interactive-globe canvas) {
      margin-inline: auto;
    }
  }
</style>

<script is:inline>
  const diffuseTargets = document.querySelectorAll("[data-letter-noise]");
  if (diffuseTargets.length > 0 && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    diffuseTargets.forEach((target) => {
      const finalText = target.getAttribute("data-letter-noise") || "";
      const overlay = target.querySelector(".diffuse-noise");
      if (!overlay) return;
      const finalChars = Array.from(finalText);
      const noisePool = finalChars.filter((char) => char !== " " && char !== "\n");
      const activeIndices = finalChars
        .map((char, index) => ({ char, index }))
        .filter((item) => item.char !== " " && item.char !== "\n")
        .map((item) => item.index);
      const noiseFrames = Array.from({ length: 42 }, (_, frameIndex) => {
        const chars = Array.from(finalText);
        for (let i = 0; i < activeIndices.length; i += 1) {
          const index = activeIndices[i];
          if (noisePool.length > 0) {
            chars[index] = noisePool[(i * 17 + frameIndex * 13) % noisePool.length];
          }
        }
        return chars.join("");
      });
      const startedAt = performance.now();
      const duration = 1000;
      let lastFrameIndex = -1;

      const tick = (now) => {
        const progress = Math.min(1, (now - startedAt) / duration);
        const frameIndex = Math.min(noiseFrames.length - 1, Math.floor(progress * noiseFrames.length));
        if (frameIndex !== lastFrameIndex) {
          overlay.textContent = noiseFrames[frameIndex];
          lastFrameIndex = frameIndex;
        }
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          overlay.textContent = finalText;
          target.classList.add("is-settled");
        }
      };

      requestAnimationFrame(tick);
    });
  }

  const denoise = document.querySelector("[data-hero-denoise]");
  const canvas = denoise?.querySelector("canvas");
  const context = canvas?.getContext("2d");
  if (denoise && canvas && context && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const rect = denoise.getBoundingClientRect();
    const aspect = rect.width > 0 ? Math.max(1, rect.height / rect.width) : 1;
    const width = 32;
    const height = Math.max(32, Math.round(width * aspect));
    const startedAt = performance.now();
    canvas.width = width;
    canvas.height = height;
    const noiseFrames = Array.from({ length: 36 }, () => {
      const frameCanvas = document.createElement("canvas");
      frameCanvas.width = width;
      frameCanvas.height = height;
      const frameContext = frameCanvas.getContext("2d");
      const frameData = frameContext?.createImageData(width, height);
      if (!frameContext || !frameData) return frameCanvas;
      const { data } = frameData;
      for (let i = 0; i < data.length; i += 4) {
        data[i] = Math.floor(Math.random() * 256);
        data[i + 1] = Math.floor(Math.random() * 256);
        data[i + 2] = Math.floor(Math.random() * 256);
        data[i + 3] = 255;
      }
      frameContext.putImageData(frameData, 0, 0);
      return frameCanvas;
    });
    let lastFrameIndex = -1;

    const draw = (progress) => {
      const frameIndex = Math.min(noiseFrames.length - 1, Math.floor(progress * noiseFrames.length));
      if (frameIndex !== lastFrameIndex) {
        context.clearRect(0, 0, width, height);
        context.drawImage(noiseFrames[frameIndex], 0, 0);
        lastFrameIndex = frameIndex;
      }
      canvas.style.opacity = `${1 - progress}`;
    };
    const tick = (now) => {
      const progress = Math.min(1, (now - startedAt) / 1000);
      draw(progress);
      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        context.clearRect(0, 0, width, height);
        canvas.style.opacity = "0";
        denoise.classList.add("is-settled");
        window.dispatchEvent(new Event("hero-denoise-complete"));
      }
    };

    draw(0);
    requestAnimationFrame(tick);
  } else {
    denoise?.classList.add("is-settled");
    window.dispatchEvent(new Event("hero-denoise-complete"));
  }
</script>
